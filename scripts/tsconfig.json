{
  "compilerOptions": {
    "outDir": "./dist",
    "types": ["node"],

    /******************************** TYPE CHECKING ******************************/
    "strict": true,
    "noImplicitAny": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    /******************************** TYPE CHECKING ******************************/

    /*********************************** MODULES *********************************/
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    /*********************************** MODULES *********************************/

    /***************************** JAVASCRIPT SUPPORT ****************************/
    "allowJs": false,
    "sourceMap": true,
    "declaration": true,
    /***************************** JAVASCRIPT SUPPORT ****************************/

    /***************************** INTEROP CONSTRAINTS ***************************/
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    /***************************** INTEROP CONSTRAINTS ***************************/

    /************************** LANGUAGE & ENVIRONMENT ***************************/
    "lib": ["ES2020", "dom"],
    "target": "ES2020",
    "useDefineForClassFields": true,
    /************************** LANGUAGE & ENVIRONMENT ***************************/

    /******************************** COMPLETENESS *******************************/
    "skipLibCheck": true
    /******************************** COMPLETENESS *******************************/
  },
  "include": ["**/*.ts"],
}
